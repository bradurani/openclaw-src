#!/bin/sh

# ecs-exec — Interactive shell into the running OpenClaw ECS container
#
# Usage: script/ecs-exec [command]
#   script/ecs-exec              # /bin/bash (as node)
#   script/ecs-exec /bin/sh      # sh (if available, as node)
#   script/ecs-exec node openclaw.mjs health --json

set -e

CLUSTER="openclaw"
CONTAINER="openclaw"
RUN_AS_USER="node"
REGION="${AWS_REGION:-us-west-2}"
COMMAND="${1:-/bin/bash}"
shift 2>/dev/null || true

TASK_ARN=$(AWS_PROFILE="${AWS_PROFILE:-openclaw-dev}" aws ecs list-tasks \
  --cluster "$CLUSTER" \
  --service-name "$CLUSTER" \
  --desired-status RUNNING \
  --region "$REGION" \
  --query 'taskArns[0]' \
  --output text)

if [ "$TASK_ARN" = "None" ] || [ -z "$TASK_ARN" ]; then
  echo "error: no running tasks in cluster $CLUSTER" >&2
  exit 1
fi

echo "Connecting to $TASK_ARN as ${RUN_AS_USER} ..."

if [ "$COMMAND" = "/bin/bash" ] && [ "$#" -eq 0 ]; then
  EXEC_COMMAND="su -s /bin/bash ${RUN_AS_USER}"
else
  EXEC_COMMAND="su -s /bin/bash ${RUN_AS_USER} -c \"$COMMAND $*\""
fi

exec env AWS_PROFILE="${AWS_PROFILE:-openclaw-dev}" aws ecs execute-command \
  --cluster "$CLUSTER" \
  --task "$TASK_ARN" \
  --container "$CONTAINER" \
  --region "$REGION" \
  --interactive \
  --command "$EXEC_COMMAND"
