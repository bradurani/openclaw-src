#!/bin/sh

# Load app secrets for local scripts (skip with OPENCLAW_SKIP_FETCH_ENV=1)
if [ -z "${OPENCLAW_SKIP_FETCH_ENV:-}" ] && [ -x "script/fetch-env" ]; then
  eval "$(script/fetch-env)"
fi
# ecs-exec — Interactive shell into the running OpenClaw ECS container
#
# Usage: script/ecs-exec [command]
#   script/ecs-exec              # /bin/sh
#   script/ecs-exec /bin/bash    # bash (if available)
#   script/ecs-exec node openclaw.mjs health --json

set -e

CLUSTER="openclaw"
CONTAINER="openclaw"
REGION="${AWS_REGION:-us-west-2}"
COMMAND="${1:-/bin/sh}"
shift 2>/dev/null || true

TASK_ARN=$(AWS_PROFILE="${AWS_PROFILE:-openclaw-dev}" aws ecs list-tasks \
  --cluster "$CLUSTER" \
  --desired-status RUNNING \
  --region "$REGION" \
  --query 'taskArns[0]' \
  --output text)

if [ "$TASK_ARN" = "None" ] || [ -z "$TASK_ARN" ]; then
  echo "error: no running tasks in cluster $CLUSTER" >&2
  exit 1
fi

echo "Connecting to $TASK_ARN ..."

exec env AWS_PROFILE="${AWS_PROFILE:-openclaw-dev}" aws ecs execute-command \
  --cluster "$CLUSTER" \
  --task "$TASK_ARN" \
  --container "$CONTAINER" \
  --region "$REGION" \
  --interactive \
  --command "$COMMAND $*"
