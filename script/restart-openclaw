#!/usr/bin/env bash
set -euo pipefail

PID1="${OPENCLAW_RESTART_PID:-1}"
TIMEOUT="${OPENCLAW_RESTART_TIMEOUT:-20}"

if ! [[ "$PID1" =~ ^[0-9]+$ ]] || [ "$PID1" -lt 1 ]; then
  echo "restart-openclaw: invalid OPENCLAW_RESTART_PID='$PID1'" >&2
  exit 1
fi

if ! [[ "$TIMEOUT" =~ ^[0-9]+$ ]]; then
  echo "restart-openclaw: invalid OPENCLAW_RESTART_TIMEOUT='$TIMEOUT'" >&2
  exit 1
fi

if ! kill -0 "$PID1" 2>/dev/null; then
  echo "restart-openclaw: pid $PID1 is not running" >&2
  exit 1
fi

echo "restart-openclaw: sending SIGTERM to pid $PID1"
kill -TERM "$PID1"

for _ in $(seq 1 "$TIMEOUT"); do
  if ! kill -0 "$PID1" 2>/dev/null; then
    echo "restart-openclaw: pid $PID1 exited"
    exit 0
  fi
  sleep 1
done

echo "restart-openclaw: pid $PID1 did not exit after ${TIMEOUT}s; sending SIGKILL"
kill -KILL "$PID1"
