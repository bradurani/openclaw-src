#!/bin/bash

# Load app secrets for local scripts (skip with OPENCLAW_SKIP_FETCH_ENV=1)
if [ -z "${OPENCLAW_SKIP_FETCH_ENV:-}" ] && [ -x "script/fetch-env" ]; then
  eval "$(script/fetch-env)"
fi

# Script to run the remote-cli service in interactive mode using docker compose

set -e

docker compose run --rm --service-ports --interactive --tty --remove-orphans remote-cli