#!/usr/bin/env node
// SecretRef exec provider for AWS Secrets Manager.
//
// Implements the OpenClaw exec provider protocol (protocolVersion 1):
//   stdin:  { "protocolVersion": 1, "provider": "...", "ids": ["openclaw/foo", ...] }
//   stdout: { "protocolVersion": 1, "values": { "openclaw/foo": "secret-value" }, "errors": {} }
//
// Uses the AWS SDK (available in the Node.js runtime) to call Secrets Manager
// directly — no subprocess overhead from shelling out to the aws CLI.

// Resolve from /app/node_modules since this script runs from /usr/local/bin
const { SecretsManagerClient, GetSecretValueCommand } = require("/app/node_modules/@aws-sdk/client-secrets-manager");

const region = process.env.AWS_REGION || process.env.AWS_DEFAULT_REGION || "us-west-2";
const client = new SecretsManagerClient({ region });

async function main() {
  const chunks = [];
  for await (const chunk of process.stdin) chunks.push(chunk);
  const request = JSON.parse(Buffer.concat(chunks).toString());
  const ids = request.ids || [];

  const results = await Promise.allSettled(
    ids.map(async (id) => {
      const cmd = new GetSecretValueCommand({ SecretId: id });
      const resp = await client.send(cmd);
      return { id, value: resp.SecretString };
    })
  );

  const values = {};
  const errors = {};
  for (let i = 0; i < results.length; i++) {
    const r = results[i];
    const id = ids[i];
    if (r.status === "fulfilled") {
      values[id] = r.value.value;
    } else {
      errors[id] = { message: r.reason?.message || String(r.reason) };
    }
  }

  process.stdout.write(JSON.stringify({ protocolVersion: 1, values, errors }));
}

main().catch((err) => {
  process.stdout.write(JSON.stringify({
    protocolVersion: 1,
    values: {},
    errors: { _fatal: { message: err.message || String(err) } },
  }));
  process.exit(1);
});
