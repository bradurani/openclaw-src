#!/usr/bin/env bash
# Load OpenClaw secrets from AWS Secrets Manager.
#
# Boot usage (entrypoint):
#   eval "$(/usr/local/bin/load-secrets --format shell)"
#
# Runtime usage (inside running container):
#   /usr/local/bin/load-secrets --reload
#
# Notes:
# - Secrets are discovered by prefix (default: openclaw/).
# - Env var names are derived by uppercasing and replacing '-' with '_'.
# - Compatibility aliases are also emitted for known legacy names.

set -euo pipefail

PREFIX="${OPENCLAW_SECRET_PREFIX:-openclaw/}"
REGION="${AWS_REGION:-${AWS_DEFAULT_REGION:-us-west-2}}"
FORMAT="shell"
RELOAD_ONLY=0

usage() {
  cat <<USAGE
Usage: load-secrets [--format shell|dotenv] [--prefix openclaw/] [--region us-west-2] [--reload]

Options:
  --format  Output format: shell (default) or dotenv
  --prefix  Secrets Manager name prefix to scan (default: openclaw/)
  --region  AWS region (default: AWS_REGION/AWS_DEFAULT_REGION/us-west-2)
  --reload  Signal PID 1 (USR1) to reload secrets and restart OpenClaw process
  -h, --help  Show help
USAGE
}

while (($# > 0)); do
  case "$1" in
    --format)
      FORMAT="$2"
      shift 2
      ;;
    --prefix)
      PREFIX="$2"
      shift 2
      ;;
    --region)
      REGION="$2"
      shift 2
      ;;
    --reload)
      RELOAD_ONLY=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "load-secrets: unknown argument: $1" >&2
      usage >&2
      exit 1
      ;;
  esac
done

if [[ "$RELOAD_ONLY" -eq 1 ]]; then
  kill -USR1 1
  exit 0
fi

if [[ "$FORMAT" != "shell" && "$FORMAT" != "dotenv" ]]; then
  echo "load-secrets: --format must be 'shell' or 'dotenv'" >&2
  exit 1
fi

emit_kv() {
  local key="$1"
  local value="$2"

  if [[ "$FORMAT" == "shell" ]]; then
    printf 'export %s=%q\n' "$key" "$value"
  else
    # dotenv output for tooling; values are emitted as-is.
    printf '%s=%s\n' "$key" "$value"
  fi
}

emit_aliases() {
  local slug="$1"
  local value="$2"

  case "$slug" in
    gateway-token)
      emit_kv "OPENCLAW_GATEWAY_TOKEN" "$value"
      ;;
    github-token)
      emit_kv "GH_TOKEN" "$value"
      ;;
  esac
}

# List secrets by prefix. We also guard with a shell prefix check for safety.
secret_names=$(aws secretsmanager list-secrets \
  --region "$REGION" \
  --filters "Key=name,Values=$PREFIX" \
  --query 'SecretList[].Name' \
  --output text)

if [[ -z "${secret_names//[[:space:]]/}" ]]; then
  exit 0
fi

while IFS= read -r secret_name; do
  [[ -z "$secret_name" ]] && continue
  [[ "$secret_name" != "$PREFIX"* ]] && continue

  slug="${secret_name#"$PREFIX"}"
  [[ -z "$slug" ]] && continue

  env_name=$(printf '%s' "$slug" | tr '[:lower:]-' '[:upper:]_')

  secret_value=$(aws secretsmanager get-secret-value \
    --region "$REGION" \
    --secret-id "$secret_name" \
    --query 'SecretString' \
    --output text)

  emit_kv "$env_name" "$secret_value"
  emit_aliases "$slug" "$secret_value"
done < <(printf '%s\n' "$secret_names" | tr '\t' '\n' | sort -u)
