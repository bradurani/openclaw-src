#!/usr/bin/env bash
# Reload secrets on the running ECS gateway without restarting.
# Triggers the SecretRef exec provider to re-fetch all secrets from AWS SM
# and atomically swap the in-memory snapshot.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR/.."

exec docker compose run --rm remote-cli gateway call secrets.reload
