#!/usr/bin/env bash
# Fetch application secrets from AWS Secrets Manager.
#
# Modes:
#   script/fetch-env              # export KEY=VALUE to stdout (for shell eval)
#                                 # — excludes GH_TOKEN (use local git creds)
#   script/fetch-env --docker     # KEY=VALUE to stdout (for docker-compose .env)
#                                 # — includes GH_TOKEN (containers need it)
#
# Examples:
#   eval "$(script/fetch-env)"                  # export into current shell
#   script/fetch-env --docker > openclaw/.env   # generate .env for docker-compose
set -euo pipefail

REGION="${AWS_REGION:-us-west-2}"
MODE="${1:-shell}"

fetch() {
  local secret_id="$1"
  aws secretsmanager get-secret-value \
    --secret-id "$secret_id" \
    --region "$REGION" \
    --query 'SecretString' \
    --output text
}

if [[ "$MODE" == "--docker" ]]; then
  # Plain KEY=VALUE for docker-compose env_file (includes GH_TOKEN)
  echo "OPENAI_API_KEY=$(fetch openclaw/openai-api-key)"
  echo "SLACK_BOT_TOKEN=$(fetch openclaw/slack-bot-token)"
  echo "SLACK_APP_TOKEN=$(fetch openclaw/slack-app-token)"
  echo "OPENCLAW_GATEWAY_TOKEN=$(fetch openclaw/gateway-token)"
  echo "PGVECTOR_URL=$(fetch openclaw/pgvector-url)"
  echo "GH_TOKEN=$(fetch openclaw/github-token)"
else
  # export KEY=VALUE for shell eval (NO GH_TOKEN — use local git creds)
  echo "export OPENAI_API_KEY=$(fetch openclaw/openai-api-key)"
  echo "export SLACK_BOT_TOKEN=$(fetch openclaw/slack-bot-token)"
  echo "export SLACK_APP_TOKEN=$(fetch openclaw/slack-app-token)"
  echo "export OPENCLAW_GATEWAY_TOKEN=$(fetch openclaw/gateway-token)"
  echo "export PGVECTOR_URL=$(fetch openclaw/pgvector-url)"
fi
