#!/usr/bin/env bash
# Fetch application secrets from AWS Secrets Manager and write them to stdout
# in KEY=VALUE format (suitable for docker compose env_file or shell eval).
#
# Usage:
#   script/fetch-env                    # print to stdout
#   script/fetch-env > openclaw/.env    # write a (gitignored) .env file
#   eval "$(script/fetch-env)"          # export into current shell
set -euo pipefail

REGION="${AWS_REGION:-us-west-2}"

fetch() {
  local secret_id="$1"
  aws secretsmanager get-secret-value \
    --secret-id "$secret_id" \
    --region "$REGION" \
    --query 'SecretString' \
    --output text
}

echo "export OPENAI_API_KEY=$(fetch openclaw/openai-api-key)"
echo "export SLACK_BOT_TOKEN=$(fetch openclaw/slack-bot-token)"
echo "export SLACK_APP_TOKEN=$(fetch openclaw/slack-app-token)"
echo "export OPENCLAW_GATEWAY_TOKEN=$(fetch openclaw/gateway-token)"
echo "export PGVECTOR_URL=$(fetch openclaw/pgvector-url)"
echo "export GH_TOKEN=$(fetch openclaw/github-token)"
